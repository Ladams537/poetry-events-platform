{
  "name": "@poetry/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@poetry/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.6",
    "hono": "^4.10.7",
    "jose": "^6.1.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
